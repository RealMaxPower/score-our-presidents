# ============================================================
# Required
# ============================================================

# Postgres connection string. Schema-validated in `lib/env.ts`.
# Local Docker (see docker-compose.yml — port 5435):
#   postgresql://postgres:postgres@localhost:5435/presidential_scoring
# Supabase (production):
#   copy the *pooled* (Supavisor, port 6543) connection string from
#   Project Settings → Database → Connection string. Append
#   ?pgbouncer=true&connection_limit=1 — required for Vercel serverless.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Migrations need a non-pooled (direct, port 5432) connection on Supabase.
# Prisma also reads this as `directUrl` per db/schema.prisma.
# For local Docker, this can be identical to DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/dbname?sslmode=require"


# ============================================================
# Auth — NextAuth.js v5 (auth.ts)
# ============================================================

# Required in production. Used by NextAuth to sign session JWTs.
# Generate with: openssl rand -base64 32
# `lib/env.ts` rejects values shorter than 32 chars at production server start.
NEXTAUTH_SECRET="dev-secret-replace-before-deploy"

# v5 detects from the request, but setting it explicitly avoids surprises
# behind proxies. Use the canonical, public-facing URL in production.
NEXTAUTH_URL="http://localhost:3000"

# Public site origin, used for canonical URLs and absolute OG images.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Production providers (optional in dev, set to activate) -----

# Google OAuth — get from console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# Provider activates in the sign-in page as soon as both are set.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic-link via Resend's REST API (wired through Auth.js's native
# `next-auth/providers/resend` in `auth.ts` — no SMTP, no extra package).
#
# Setup:
#   1. Create an API key at resend.com → API Keys (starts with `re_`).
#      Name it `AUTH_RESEND_KEY` exactly — Auth.js auto-detects this name.
#   2. Add + verify your sending domain at resend.com → Domains.
#   3. Set EMAIL_FROM to any address on that verified domain.
#
# Provider activates as soon as both AUTH_RESEND_KEY and EMAIL_FROM are set.
AUTH_RESEND_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# --- Dev fallbacks --- REQUIRED to be "1" in production ----------
# Both flags below MUST be set to "1" in production. `lib/env.ts` refuses
# to boot the server otherwise. Reason: leaving them unset keeps two
# trivial-takeover paths active —
#   - Credentials provider in auth.ts: email-only sign-in for any seeded
#     UserProfile (no password).
#   - psf_session cookie fallback in lib/auth.ts: unsigned email string
#     in a cookie; forging it impersonates that user.
# Leave empty in dev for the local sign-in form to work.

AUTH_DISABLE_DEV_CREDENTIALS=""
AUTH_DISABLE_DEV_COOKIE=""


# ============================================================
# Admin second factor — REQUIRED IN PRODUCTION
# ============================================================
# Shared secret that gates /admin/* on top of the NextAuth session +
# isAdmin check. An admin signs into the site normally, then visits
# /admin/unlock once per browser to exchange this token for a scoped
# cookie. Even with a stolen session cookie an attacker can't reach
# /admin without also having this token.
#
# Generate with: openssl rand -base64 32
# `lib/env.ts` rejects values shorter than 32 chars at production start.
# Optional in dev — leave empty to disable the second-factor check.
ADMIN_TOKEN=""


# ============================================================
# Rate limiting — Upstash Redis
# ============================================================
# REQUIRED IN PRODUCTION. `lib/env.ts` refuses to boot without both.
# Reason: without Upstash, rate limits fall back to a per-process in-memory
# Map. On serverless (Vercel) each cold invocation may get a fresh process,
# so limits effectively don't enforce.
# Optional in dev — leave empty to use the in-memory fallback.
# Get from console.upstash.com → Redis → REST API.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ============================================================
# Observability (optional, production-only)
# ============================================================

# Sentry DSN for server-side error reporting. When set, instrumentation.ts
# initializes the SDK at boot. Get from sentry.io → Project Settings →
# Client Keys (DSN). Recommended in production.
SENTRY_DSN=""

# Optional: also report errors from the browser. Set this to the same DSN
# value if you want client-side coverage. Kept as a separate env so the
# server-only DSN never leaks into client bundles unintentionally.
NEXT_PUBLIC_SENTRY_DSN=""

# Page analytics: Vercel Analytics is wired in app/layout.tsx via
# @vercel/analytics — no env var. Enable per-environment from the Vercel
# dashboard (Project → Analytics). Cookieless, no PII.

# Log level for the structured logger. One of: debug | info | warn | error.
LOG_LEVEL="info"
