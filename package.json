{
  "name": "score-our-presidents",
  "version": "0.1.0",
  "private": true,
  "description": "A reproducible editorial framework for scoring US presidencies on 13 categories and 56 sub-criteria, with per-president evidence YAMLs and a published lens-weighting system. Code MIT; spec CC BY-SA 4.0; scoring evidence CC BY 4.0.",
  "license": "MIT",
  "author": "Marshall Cahill <editorial@scoreourpresidents.org>",
  "homepage": "https://www.scoreourpresidents.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/RealMaxPower/score-our-presidents.git"
  },
  "bugs": {
    "url": "https://github.com/RealMaxPower/score-our-presidents/issues",
    "email": "editorial@scoreourpresidents.org"
  },
  "keywords": [
    "presidential-rankings",
    "political-science",
    "open-data",
    "editorial-methodology",
    "next.js",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate --schema=db/schema.prisma",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "prisma migrate reset --force && pnpm db:seed",
    "db:studio": "prisma studio",
    "verify-rankings": "python3 scripts/compute_rankings.py"
  },
  "prisma": {
    "schema": "db/schema.prisma",
    "seed": "tsx db/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^5.20.0",
    "@sentry/nextjs": "^10.58.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "next": "^15.5.18",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "server-only": "^0.0.1",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.14",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "8.0.16",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.10.0",
  "pnpm": {
    "overrides": {
      "rollup": ">=3.30.0",
      "postcss": ">=8.5.10",
      "uuid": "^11.1.1",
      "esbuild": ">=0.28.1",
      "vite": "8.0.16",
      "js-yaml": ">=4.2.0",
      "@babel/core": ">=7.29.6 <8"
    }
  }
}
